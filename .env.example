# ===== Moka MCP Server 配置模板 =====
# 复制本文件为 .env 并填入真实值

# Moka API Key（由 CSM 发放，用于 Basic Auth）
MOKA_API_KEY=your_api_key_here

# 组织标识（由 CSM 提供），职位类接口需要
MOKA_ORG_ID=your_org_id
# 运行环境：production | staging
MOKA_ENV=production

# 可选：直接覆盖 Base URL（一般无需设置，按 MOKA_ENV 自动选择）
# MOKA_BASE_URL=https://api.mokahr.com/api-platform/v1

# 是否对敏感字段（手机号/身份证）脱敏：true | false
MOKA_MASK_SENSITIVE=true

# HTTP 请求超时（秒）
MOKA_TIMEOUT=30

# 自动翻页时最多拉取的条数上限（防止一次拉取过多数据）
MOKA_MAX_ITEMS=200

# ===== MCP Server 传输方式 =====
# stdio：本地子进程（Claude Desktop / Cursor）；http：自托管 HTTP 端点（Hermes/mcporter）
MOKA_TRANSPORT=stdio

# 仅当 MOKA_TRANSPORT=http 时生效：
MOKA_HTTP_HOST=0.0.0.0
MOKA_HTTP_PORT=8000
MOKA_HTTP_PATH=/mcp
# agent 接入时须在 X-API-Key 头携带该值；留空则不校验（仅限可信内网）
# 与 MOKA_API_KEY（访问 Moka 用）是两套不同凭证，请勿混用
MOKA_MCP_API_KEY=

# ===== 权限控制（stdio：每个实例 = 一个调用者，由 Hermes 按 Slack 用户注入）=====
# 角色：hr_admin/admin（全部）| recruiter（全量读）| hiring_manager（仅本部门）| viewer（公开信息，无候选人PII）
MOKA_ROLE=hr_admin
# 数据范围（留空按 role 推断）：all | department
MOKA_SCOPE=
# department 范围用：逗号分隔的部门名，如 产品部,技术部（hiring_manager 必填）
MOKA_DEPARTMENTS=
# 工具白名单覆盖（逗号分隔，* 表示全部）；留空按 role 推断
MOKA_ALLOWED_TOOLS=
